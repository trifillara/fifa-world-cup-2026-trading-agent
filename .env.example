# Signer private key (never commit real keys)
POLYMARKET_PRIVATE_KEY=

# Polymarket proxy / Safe that holds USDC
POLYMARKET_FUNDER_ADDRESS=

# EOA | POLY_PROXY | POLY_GNOSIS_SAFE | POLY_1271
POLYMARKET_SIGNATURE_TYPE=POLY_PROXY

# Comma-separated leader wallets — prefix with whale: or trader:
# whale:0xabc...:WhaleOne,trader:0xdef...:TopTrader
LEADER_WALLETS=

# true = log orders only, false = live trading
DRY_RUN=true

# Redis (optional) — persists seen leader activity across restarts
# REDIS_ENABLED=true
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_DB=0
